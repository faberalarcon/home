---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="21 Bristoe"
  description="Welcome home — Faber, Kasey, and Limón at Meades Crossing, Taneytown, Maryland."
>
  <main id="main-content" class="min-h-screen flex flex-col items-center justify-center">
    <div class="text-center px-4">
      <h1 class="text-5xl font-bold mb-4" style="font-family: var(--font-display); color: var(--color-warm-500);">
        21 Bristoe
      </h1>
      <p class="text-xl text-gray-600 mb-2">Home of Faber, Kasey & Limón</p>
      <p class="text-base text-gray-400">Meades Crossing · Taneytown, Maryland</p>
      <p class="mt-8 text-sm text-gray-400 italic">Site coming soon — building something warm.</p>
    </div>
  </main>
</BaseLayout>
