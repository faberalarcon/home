---
import fs from 'node:fs';

const year = new Date().getFullYear();

let visitorCount: number | null = null;
try {
  const raw = fs.readFileSync('/var/lib/bristoe-stats/visitors.json', 'utf8');
  const data = JSON.parse(raw);
  if (typeof data.count === 'number') visitorCount = data.count;
  else if (Array.isArray(data.uniqueHashes)) visitorCount = data.uniqueHashes.length;
} catch {
  visitorCount = null;
}
---

<footer class="w-full bg-warm-900 text-warm-100 py-12 px-6 mt-auto">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <!-- Left: branding -->
      <div>
        <p class="text-2xl font-bold text-warm-200 mb-1 font-display">21 Bristoe</p>
        <p class="text-warm-400 text-sm">Meades Crossing · Taneytown, Maryland</p>
        <p class="text-warm-500 text-xs mt-1">Home of Faber, Kasey & Limón</p>
      </div>

      <!-- Right: links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-col gap-2 text-sm list-none" role="list">
          <li>
            <a
              href="https://drink-hub.21bristoe.com"
              class="text-warm-300 hover:text-warm-100 transition-colors"
              target="_blank"
              rel="noopener noreferrer"
            >
              Drink Hub →
            </a>
          </li>
        </ul>
      </nav>
    </div>

    {visitorCount !== null && (
      <div class="mt-8 pt-6 border-t border-warm-800 text-center">
        <p class="text-warm-300 text-sm">
          <span aria-hidden="true">👋</span>
          <span id="footerVisitorCount" class="tabular-nums font-semibold text-warm-100">{visitorCount.toLocaleString()}</span>
          <span class="text-warm-400">unique visitors so far</span>
        </p>
      </div>
    )}

    <script>
      // Keep visitor count live without a full rebuild — fetch the public count file
      // written by parse-visitors.mjs and the admin reset endpoint.
      document.addEventListener('astro:page-load', () => {
        const el = document.getElementById('footerVisitorCount');
        if (!el) return;
        fetch('/uploads/visitor-count.json')
          .then(r => r.ok ? r.json() : null)
          .then(d => { if (d && typeof d.count === 'number') el.textContent = d.count.toLocaleString(); })
          .catch(() => {});
      });
    </script>

    <!-- Bottom bar -->
    <div class="mt-8 pt-6 border-t border-warm-800 text-warm-500 text-xs flex flex-col sm:flex-row justify-between gap-2">
      <p>© {year} 21 Bristoe. Made with love for the household.</p>
      <p>
        Built by Faber Alarcon ·
        <a
          href="https://github.com/faberalarcon/home"
          class="text-warm-400 hover:text-warm-200 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >GitHub</a>
      </p>
    </div>
  </div>
</footer>
