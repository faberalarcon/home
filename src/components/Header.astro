---
// Header component — minimal site nav
---

<header class="w-full py-4 px-6 bg-warm-50/95 backdrop-blur-sm border-b border-warm-200 sticky top-0 z-50">
  <nav class="max-w-5xl mx-auto flex items-center justify-between" aria-label="Main navigation">
    <a
      href="/"
      class="flex items-center gap-2 text-warm-700 hover:text-warm-500 transition-colors focus-visible:outline-warm-500"
      aria-label="21 Bristoe — home"
    >
      <!-- House icon -->
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2L2 10.5h2V21h6v-6h4v6h6V10.5h2L12 2z"/>
      </svg>
      <span class="font-bold text-lg tracking-tight" style="font-family: var(--font-display);">21 Bristoe</span>
    </a>

    <!-- Navigation links -->
    <ul class="flex items-center gap-6 text-sm font-medium list-none" role="list">
      <li>
        <a href="#neighborhood" class="text-warm-700 hover:text-warm-500 transition-colors">Neighborhood</a>
      </li>
      <li>
        <a href="#limon" class="text-warm-700 hover:text-warm-500 transition-colors">Limón</a>
      </li>
      <li>
        <a
          href="https://drink-hub.21bristoe.com"
          class="px-3 py-1.5 bg-warm-500 text-white rounded-md text-sm font-medium hover:bg-warm-600 transition-colors"
          target="_blank"
          rel="noopener noreferrer"
        >
          Drink Hub
        </a>
      </li>
    </ul>
  </nav>
</header>
