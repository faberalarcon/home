---
// Welcome section — household introduction
import fs from 'node:fs';

// A3: Seasonal greeting — computed at build time
const month = new Date().getMonth();
const season =
  month === 11        ? 'winter-holiday'
  : month <= 1        ? 'winter'
  : month <= 4        ? 'spring'
  : month <= 7        ? 'summer'
  :                     'autumn';

const seasonalNote: Record<string, string> = {
  'winter-holiday': 'Happy holidays from 21 Bristoe — wishing you warmth and joy this season.',
  winter:           "Good winter from 21 Bristoe — hope you're staying cozy.",
  spring:           'Good spring from 21 Bristoe — glad you stopped by.',
  summer:           "Good summer from 21 Bristoe — hope it's a great one.",
  autumn:           "Good autumn from 21 Bristoe — it's our favorite time of year.",
};

// A4: Household member vignettes — read from admin-managed site-config, fallback to defaults
const defaultMembers = [
  {
    name: 'Faber',
    emoji: '👨',
    role: 'Co-owner',
    bio: 'Loves a good cocktail, a well-crafted home project, and getting into the weeds on anything tech.',
    cardClass: 'bg-warm-50 border-warm-200',
    photoFile: null as string | null,
  },
  {
    name: 'Kasey',
    emoji: '👩',
    role: 'Co-owner',
    bio: 'Great cook, great eye for design, and the reason 21 Bristoe actually feels like a home.',
    cardClass: 'bg-sage-50 border-sage-200',
    photoFile: null as string | null,
  },
  {
    name: 'Limón',
    emoji: '🐕',
    role: 'Chief Joy Officer',
    bio: 'Certified zoomie expert. Will greet you at the door, steal your spot on the couch, and charm everyone in the room.',
    cardClass: 'bg-warm-100 border-warm-300',
    photoFile: null as string | null,
  },
];

let members = defaultMembers;
let welcomeLabel = 'The Household';
let welcomeHeading = 'Welcome to Our Home';
let welcomePara1 = "We're Faber and Kasey, and we've made our home here in Meades Crossing — a neighborhood in Taneytown, Maryland that we're proud to be part of.";
let welcomePara2 = "Whether it's a quiet evening on the back porch, a morning walk through the neighborhood, or hosting friends over a good meal and a great drink, 21 Bristoe is where life happens for us.";
let welcomePara3 = "This little corner of the internet is our household portal — a place to share what we're up to, what we love, and yes, plenty of Limón content.";
let accentAddress = '21 Bristoe Station Rd';
let accentCity = 'Taneytown, MD';
try {
  const raw = fs.readFileSync('/var/www/21bristoe-media/site-config.json', 'utf8');
  const cfg = JSON.parse(raw);
  if (Array.isArray(cfg.members) && cfg.members.length > 0) {
    members = cfg.members.map((m: typeof defaultMembers[0], i: number) => ({
      ...defaultMembers[i],
      ...m,
      cardClass: defaultMembers[i]?.cardClass ?? defaultMembers[0].cardClass,
    }));
  }
  const wt = cfg.sectionText?.welcome || {};
  if (wt.label) welcomeLabel = wt.label;
  if (wt.heading) welcomeHeading = wt.heading;
  if (wt.para1) welcomePara1 = wt.para1;
  if (wt.para2) welcomePara2 = wt.para2;
  if (wt.para3) welcomePara3 = wt.para3;
  if (wt.accentAddress) accentAddress = wt.accentAddress;
  if (wt.accentCity) accentCity = wt.accentCity;
} catch { /* no config yet — use defaults */ }
---

<section
  class="py-20 px-6 bg-warm-50"
  aria-labelledby="welcome-heading"
>
  <div class="max-w-5xl mx-auto reveal">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Text content -->
      <div>
        <p class="text-warm-500 text-sm font-medium uppercase tracking-widest mb-3">{welcomeLabel}</p>
        <h2
          id="welcome-heading"
          class="text-4xl md:text-5xl font-bold text-warm-800 mb-3 font-display"
        >
          {welcomeHeading}
        </h2>
        <!-- A3: Seasonal tagline -->
        <p class="text-warm-500 italic text-sm mb-6">{seasonalNote[season]}</p>
        <div class="space-y-4 text-gray-600 leading-relaxed">
          <p>{welcomePara1}</p>
          <p>{welcomePara2}</p>
          <p>{welcomePara3}</p>
        </div>
      </div>

      <!-- Visual accent card -->
      <div
        class="rounded-3xl overflow-hidden aspect-[4/3] bg-gradient-to-br from-warm-200 via-warm-300 to-sage-300 flex items-center justify-center shadow-xl"
        aria-hidden="true"
      >
        <div class="text-center text-warm-700 p-8">
          <div class="text-7xl mb-4">🏡</div>
          <p class="font-medium text-lg font-display">{accentAddress}</p>
          <p class="text-sm text-warm-600 mt-1">{accentCity}</p>
        </div>
      </div>
    </div>

    <!-- A4: Household member cards -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-3 gap-6">
      {members.map((member) => (
        <div class={`rounded-2xl border p-6 shadow-sm ${member.cardClass}`}>
          <!-- Photo (if uploaded) or emoji fallback -->
          {member.photoFile ? (
            <div class="mb-3 relative w-16 h-16">
              <img
                hidden
                class="member-photo w-16 h-16 rounded-full object-cover"
                data-member={member.name.toLowerCase()}
                src={`/uploads/${member.photoFile}`}
                alt={member.name}
              />
              <div
                class="member-emoji text-3xl w-16 h-16 flex items-center justify-center"
                data-member={member.name.toLowerCase()}
                aria-hidden="true"
              >{member.emoji}</div>
            </div>
          ) : (
            <div class="text-3xl mb-3" aria-hidden="true">{member.emoji}</div>
          )}
          <h3 class="text-warm-800 font-bold text-lg font-display mb-0.5">{member.name}</h3>
          <p class="text-warm-500 text-xs font-medium uppercase tracking-wide mb-3">{member.role}</p>
          <p class="text-gray-600 text-sm leading-relaxed">{member.bio}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- Member photo reveal — runs on every navigation via astro:page-load -->
  <script>
    document.addEventListener('astro:page-load', () => {
      document.querySelectorAll<HTMLImageElement>('.member-photo').forEach(img => {
        const name = img.dataset.member;
        const fallback = document.querySelector<HTMLElement>(`.member-emoji[data-member="${name}"]`);
        function show() {
          img.removeAttribute('hidden');
          fallback?.setAttribute('hidden', '');
        }
        if (img.complete && img.naturalWidth > 0) show();
        else img.addEventListener('load', show);
      });
    });
  </script>
</section>
