---
// Hero section — full-viewport with dynamic photo slideshow
import Slideshow from './Slideshow.astro';
import fs from 'node:fs';

let heroConfig = {};
try {
  const raw = fs.readFileSync('/var/www/21bristoe-media/site-config.json', 'utf8');
  heroConfig = JSON.parse(raw).hero || {};
} catch { /* no config yet — use defaults */ }

const subtitle = heroConfig.subtitle || 'Home of Faber, Kasey & Limón';
const location = heroConfig.location || 'Meades Crossing · Taneytown, Maryland';
---

<section
  class="relative w-full min-h-[90vh] md:min-h-screen flex items-center justify-center overflow-hidden"
  aria-label="Welcome hero"
>
  <!-- Slideshow (gradient fallback built in when no photos uploaded yet) -->
  <Slideshow />

  <!-- Content -->
  <div class="relative z-20 text-center px-6 max-w-4xl mx-auto">
    <!-- Pre-heading -->
    <p class="text-warm-300 text-sm md:text-base font-medium uppercase tracking-widest mb-4 drop-shadow">
      Welcome Home
    </p>

    <!-- Main heading — font-family via scoped CSS to avoid inline style= attribute -->
    <h1 class="hero-title text-6xl md:text-8xl lg:text-9xl font-bold text-warm-50 mb-6 leading-none drop-shadow-lg">
      21 Bristoe
    </h1>

    <!-- Subtitle -->
    <p class="text-warm-100 text-xl md:text-2xl mb-4 font-light drop-shadow">
      {subtitle}
    </p>

    <!-- Location -->
    <p class="text-warm-300 text-base md:text-lg flex items-center justify-center gap-2 drop-shadow">
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
      </svg>
      {location}
    </p>

    <!-- Scroll cue -->
    <a href="#neighborhood" class="scroll-cue mt-16 inline-flex flex-col items-center gap-2 text-warm-200 hover:text-warm-50 transition-colors drop-shadow" aria-label="Scroll to neighborhood">
      <span class="text-xs uppercase tracking-widest">Explore</span>
      <svg class="w-5 h-5 scroll-cue-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
      </svg>
    </a>
  </div>
</section>

<style>
  /* Scoped to Hero — avoids inline style= attribute on h1 */
  .hero-title {
    font-family: var(--font-display);
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateY(0); opacity: 0.6; }
    50%      { transform: translateY(6px); opacity: 1; }
  }

  .scroll-cue-chevron {
    animation: scroll-bob 1.8s ease-in-out infinite;
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue-chevron { animation: none; opacity: 0.8; }
  }
</style>
