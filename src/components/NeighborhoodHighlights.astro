---

<section id="neighborhood" class="py-20 px-6 bg-white" aria-labelledby="neighborhood-heading">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-sage-600 text-sm font-medium uppercase tracking-widest mb-2">Where We Live</p>
      <h2
        id="neighborhood-heading"
        class="text-4xl md:text-5xl font-bold text-warm-800 mb-4"
        style="font-family: var(--font-display);"
