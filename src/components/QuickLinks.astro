---
// QuickLinks section — useful links and household quick actions
import WeatherCard from './WeatherCard.astro';

const links = [
  {
    icon: '🍹',
    title: 'Drink Hub',
    description: 'Browse our cocktail recipes, home bar inventory, and drink recommendations.',
    href: 'https://drink-hub.21bristoe.com',
    accent: 'bg-warm-50 border-warm-200 hover:border-warm-400',
    iconBg: 'bg-warm-100',
  },
  {
    icon: '🏛️',
    title: 'Carroll County',
    description: 'Local government, services, parks, and community resources for Carroll County residents.',
    href: 'https://ccgovernment.carr.org',
    accent: 'bg-warm-50 border-warm-200 hover:border-warm-400',
    iconBg: 'bg-warm-100',
  },
  {
    icon: '🗺️',
    title: 'Taneytown, MD',
    description: 'Explore Taneytown on the map — parks, local businesses, and all the spots we love.',
    href: 'https://www.google.com/maps/search/Taneytown+MD',
    accent: 'bg-sage-50 border-sage-200 hover:border-sage-400',
    iconBg: 'bg-sage-100',
  },
];
---

<section class="py-20 px-6 bg-white" aria-labelledby="quicklinks-heading">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-14">
      <p class="text-warm-500 text-sm font-medium uppercase tracking-widest mb-2">Around the House</p>
      <h2
        id="quicklinks-heading"
        class="text-4xl md:text-5xl font-bold text-warm-800 mb-4 font-display"
      >
        Quick Links
      </h2>
      <p class="text-gray-500 text-lg max-w-xl mx-auto">
        The household's most-used links and resources, one click away.
      </p>
    </div>

    <!-- Links grid — 2 columns on sm+. WeatherCard takes the top-right slot. -->
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
      <!-- Drink Hub -->
      <a
        href={links[0].href}
        class={`group flex gap-5 p-6 rounded-2xl border-2 transition-all duration-200 shadow-sm hover:shadow-md ${links[0].accent}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${links[0].title} (opens in new tab)`}
      >
        <div class={`flex-shrink-0 w-12 h-12 rounded-xl ${links[0].iconBg} flex items-center justify-center text-2xl`} aria-hidden="true">
          {links[0].icon}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-warm-800 group-hover:text-warm-600 transition-colors flex items-center gap-2">
            {links[0].title}
            <svg class="w-3.5 h-3.5 text-warm-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </h3>
          <p class="text-gray-500 text-sm mt-1 leading-relaxed">{links[0].description}</p>
        </div>
      </a>

      <!-- Live weather widget (replaces static weather link) -->
      <WeatherCard />

      <!-- Carroll County -->
      <a
        href={links[1].href}
        class={`group flex gap-5 p-6 rounded-2xl border-2 transition-all duration-200 shadow-sm hover:shadow-md ${links[1].accent}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${links[1].title} (opens in new tab)`}
      >
        <div class={`flex-shrink-0 w-12 h-12 rounded-xl ${links[1].iconBg} flex items-center justify-center text-2xl`} aria-hidden="true">
          {links[1].icon}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-warm-800 group-hover:text-warm-600 transition-colors flex items-center gap-2">
            {links[1].title}
            <svg class="w-3.5 h-3.5 text-warm-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </h3>
          <p class="text-gray-500 text-sm mt-1 leading-relaxed">{links[1].description}</p>
        </div>
      </a>

      <!-- Taneytown map -->
      <a
        href={links[2].href}
        class={`group flex gap-5 p-6 rounded-2xl border-2 transition-all duration-200 shadow-sm hover:shadow-md ${links[2].accent}`}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={`${links[2].title} (opens in new tab)`}
      >
        <div class={`flex-shrink-0 w-12 h-12 rounded-xl ${links[2].iconBg} flex items-center justify-center text-2xl`} aria-hidden="true">
          {links[2].icon}
        </div>
        <div class="flex-1 min-w-0">
          <h3 class="font-semibold text-warm-800 group-hover:text-warm-600 transition-colors flex items-center gap-2">
            {links[2].title}
            <svg class="w-3.5 h-3.5 text-warm-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </h3>
          <p class="text-gray-500 text-sm mt-1 leading-relaxed">{links[2].description}</p>
        </div>
      </a>
    </div>
  </div>
</section>
