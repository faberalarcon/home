---
// Limón Spotlight — the golden retriever feature section

const facts = [
  { label: 'Breed', value: 'Golden Retriever' },
  { label: 'Specialty', value: 'Maximum cuteness' },
  { label: 'Hobbies', value: 'Walks, naps, zoomies' },
  { label: 'Mood', value: 'Always happy to see you' },
];
---

<section id="limon" class="py-20 px-6 bg-gradient-to-br from-warm-100 to-warm-50" aria-labelledby="limon-heading">
  <div class="max-w-5xl mx-auto reveal">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      <!-- Photo (uploaded) or emoji fallback -->
      <div
        class="order-2 md:order-1 rounded-3xl overflow-hidden aspect-square shadow-2xl relative"
        aria-label="Limón the golden retriever"
      >
        <!-- Uploaded profile photo — hidden until it loads successfully -->
        <img
          id="limonProfileImg"
          hidden
          src="/uploads/limon-profile.jpg"
          alt="Limón the golden retriever"
          class="w-full h-full object-cover"
        />

        <!-- Emoji fallback shown when no photo is uploaded -->
        <div
          id="limonFallback"
          class="w-full h-full bg-gradient-to-br from-warm-300 via-warm-400 to-warm-500 flex items-center justify-center relative"
        >
          <div class="absolute inset-0 bg-gradient-to-t from-warm-600/30 to-transparent" aria-hidden="true"></div>
          <div class="relative text-center p-8">
            <div class="text-8xl mb-4" role="img" aria-label="Dog emoji">🐕</div>
            <p class="text-warm-900 font-bold text-2xl font-display">Limón</p>
            <p class="text-warm-800 text-sm mt-1">The Golden Girl</p>
          </div>
          <span class="absolute top-6 right-6 text-warm-200 text-2xl opacity-50" aria-hidden="true">🐾</span>
          <span class="absolute bottom-6 left-6 text-warm-200 text-2xl opacity-50" aria-hidden="true">🐾</span>
        </div>
      </div>

      <script>
        const img = document.getElementById('limonProfileImg');
        const fallback = document.getElementById('limonFallback');
        if (img && fallback) {
          function showPhoto() {
            img.removeAttribute('hidden');
            fallback.setAttribute('hidden', '');
          }
          // Module scripts are deferred — the image may have already loaded by
          // the time this runs, so check img.complete before adding the listener.
          if (img.complete && img.naturalWidth > 0) {
            showPhoto();
          } else {
            img.addEventListener('load', showPhoto);
            // On error keep fallback visible (already the default state)
          }
        }
      </script>

      <!-- Text content -->
      <div class="order-1 md:order-2">
        <p class="text-warm-500 text-sm font-medium uppercase tracking-widest mb-3">Meet the Resident Expert</p>
        <h2
          id="limon-heading"
          class="text-4xl md:text-5xl font-bold text-warm-800 mb-6 font-display"
        >
          Limón
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Limón is our golden retriever and the undisputed heart of the household. Named for the
          sunshine-yellow coat and the bright energy she brings to every single morning. Whether
          she's greeting you at the door, stealing a spot on the couch, or doing zoomies through
          the backyard — life with Limón is never boring.
        </p>

        <!-- Facts grid -->
        <dl class="grid grid-cols-2 gap-4">
          {facts.map(({ label, value }) => (
            <div class="bg-white rounded-xl p-4 border border-warm-200 shadow-sm">
              <dt class="text-xs font-semibold text-warm-500 uppercase tracking-wide mb-1">{label}</dt>
              <dd class="text-warm-800 font-medium text-sm">{value}</dd>
            </div>
          ))}
        </dl>

        <!-- Fun quote -->
        <blockquote class="mt-8 pl-4 border-l-4 border-warm-400">
          <p class="text-warm-700 italic text-base leading-relaxed">
            "She has never met a stranger. She has also never turned down a treat."
          </p>
          <cite class="text-warm-500 text-sm mt-2 block not-italic">— Faber & Kasey</cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>
