{
  "name": "21bristoe-home",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite dev --host 0.0.0.0",
    "build": "svelte-kit sync && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node build/index.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/drinks/server/db/migrate.ts",
    "db:seed": "tsx src/lib/drinks/server/db/seed.ts",
    "hash:secret": "node scripts/hash-secret.mjs"
  },
  "dependencies": {
    "@ip-location-db/dbip-city-mmdb": "^2.3.2026050119",
    "better-sqlite3": "^11.8.1",
    "chart.js": "^4.4.8",
    "dompurify": "^3.4.8",
    "drizzle-orm": "^0.45.2",
    "katex": "^0.17.0",
    "marked": "^18.0.4",
    "marked-katex-extension": "^5.1.10",
    "maxmind": "^5.0.6",
    "sharp": "^0.34.5",
    "shiki": "^4.2.0",
    "suncalc": "^1.9.0",
    "svelte-chartjs": "^4.0.1",
    "undici": "^8.3.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.57.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "svelte": "^5.55.3",
    "svelte-check": "^4.5.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
