SITE_PASSWORD=
SITE_PASSWORD_HASH=

# Admin password. Leave blank to let the server generate a random temporary
# password on first boot (printed to stdout). Change later from /admin/settings.
ADMIN_PASSWORD=

# Optional: ≥32 char secret used to sign session cookies. If unset, a random
# secret is auto-generated and stored in the settings table on first boot.
SESSION_SECRET=

# Set to 1 on cloud/public deployments to refuse HA base URLs that resolve to
# private/LAN ranges. On-LAN deployments (Home Assistant on the same network)
# should leave this unset — loopback/metadata targets are always refused
# regardless.
# HA_STRICT_PUBLIC=1

# Public URL of the site — used by SvelteKit to verify CSRF origins
BASE_PATH=/drinks
ORIGIN=https://21bristoe.com
CSRF_TRUSTED_ORIGINS=https://21bristoe.com
